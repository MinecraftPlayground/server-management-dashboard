{
  "license": "LGPL-3.0-only",
  "tasks": {
    "clear:dist": "rm -rf ./dist/*",
    "clear:reports": "rm -rf ./reports/*",
    "copy:assets": "mkdir -p ./dist/static/ ; cp -r ./src/client/static/* ./dist/static/ ; cp ./src/client/font/*.ttf ./dist/",
    "clear:dist-copy:assets": "deno task clear:dist ; deno task copy:assets",
    "build": {
      "description": "Build the app for production.",
      "command": "deno bundle --minify --platform=browser --external=*.ttf --outdir=./dist/ ./src/client/routes/index.html",
      "dependencies": [ "clear:dist-copy:assets" ]
    },
    "build:watch": {
      "description": "Build the app for production with watcher.",
      "command": "deno bundle --watch --minify --platform=browser --external=*.ttf --outdir=./dist/ ./src/client/routes/index.html",
      "dependencies": [ "clear:dist-copy:assets" ]
    },
    "build:development": {
      "description": "Build the app for development.",
      "command": "deno bundle --keep-names --sourcemap --platform=browser --external=*.ttf --outdir=./dist/ ./src/client/routes/index.html",
      "dependencies": [ "clear:dist-copy:assets" ]
    },
    "build:development:watch": {
      "description": "Build the app for development with watcher.",
      "command": "deno bundle --watch --keep-names --sourcemap --platform=browser --external=*.ttf --outdir=./dist/ ./src/client/routes/index.html",
      "dependencies": [ "clear:dist-copy:assets" ]
    },
    "serve": {
      "description": "Run the server (default on port 8000) for production.",
      "command": "deno run -A ./src/server/index.ts",
      "dependencies": [ "build" ]
    },
    "serve:watch": {
      "description": "Run the server (default on port 8000) for production with watcher.",
      "command": "deno run --watch -A ./src/server/index.ts",
      "dependencies": [ "build" ]
    },
    "serve:development": {
      "description": "Run the server (default on port 8000) for development.",
      "command": "deno run -A ./src/server/index.ts",
      "dependencies": [ "build:development" ]
    },
    "serve:development:watch": {
      "description": "Run the server (default on port 8000) for development with watcher.",
      "command": "deno run --watch -A ./src/server/index.ts",
      "dependencies": [ "build:development" ]
    },
    "install": {
      "description": "Install all dependencies specified in the \"deno.lock\" file.",
      "command": "deno install"
    },
    "cache-reload": {
      "description": "Reload the dependency cache.",
      "command": "deno cache --reload ."
    },
    "lint": {
      "description": "Run linter.",
      "command": "deno lint"
    },
    "test": {
      "description": "Run unit tests. Junit reports will be saved to \"./reports/report.xml\".",
      "command": "deno test -A --check --reload --doc --permit-no-files --junit-path=\"./reports/report.xml\"",
      "dependencies": [ "clear:reports" ]
    }
  },
  "unstable": [
    "bundle",
    "raw-imports"
  ],
  "compilerOptions": {
    "lib": [
      "dom",
      "webworker",
      "deno.ns"
    ]
  },
  "exclude": [
    "./dist/"
  ],
  "test": {
    "include": [
      "**/*.test.ts"
    ]
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "camelcase",
        "default-param-last",
        "eqeqeq",
        "explicit-function-return-type",
        "explicit-module-boundary-types",
        "guard-for-in",
        "no-const-assign",
        "no-eval",
        "no-external-import",
        "no-non-null-asserted-optional-chain",
        "no-non-null-assertion",
        "no-self-compare",
        "no-sparse-arrays",
        "no-sync-fn-in-async-fn",
        "no-throw-literal",
        "no-undef",
        "prefer-ascii",
        "single-var-declarator",
        "verbatim-module-syntax"
      ],
      "exclude": [
        "no-inferrable-types"
      ]
    }
  },
  "fmt": {
    "options": {
      "singleQuote": true,
      "lineWidth": 120
    }
  },
  "imports": {
    "$/": "./src/client/",
    "@std/cli": "jsr:@std/cli@^1.0.6",
    "@std/fs": "jsr:@std/fs@^1.0.20",
    "@std/http": "jsr:@std/http@^1.0.22",
    "@std/fmt": "jsr:@std/fmt@^1.0.2",
    "@std/path": "jsr:@std/path@^1.1.3",
    "@lit": "npm:lit@^3.3.3",
    "@lit/decorators": "npm:lit@^3.3.3/decorators.js"
  }
}
